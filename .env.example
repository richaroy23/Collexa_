# ── Collexa Backend Environment Variables ──────────────────
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:   mongodb://localhost:27017/collexa
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/collexa?retryWrites=true&w=majority&appName=Collexa
#          Get this from: Atlas Dashboard -> Cluster -> Connect -> Drivers -> Copy URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/collexa?retryWrites=true&w=majority&appName=Collexa

# JWT secret key (change this to a long random string in production)
JWT_SECRET_KEY=collexa-change-this-in-production-use-a-long-random-string

# GROQ API Key
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=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

